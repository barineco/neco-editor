    - match: '(#""")'
      captures:
        1: punctuation.delimiter.pkl
      push:
        - meta_scope: string.quoted.triple.1.pkl
        - match: '("""#)'
          captures:
            1: punctuation.delimiter.pkl
          pop: true
        - match: '\\#(?:[trn"\\]|u\{[\da-fA-F]+\}|\(.+?\))|(\\#.)'
          scope: constant.character.escape.1.pkl
          captures:
